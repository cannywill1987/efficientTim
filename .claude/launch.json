{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flutter Web (Chrome)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "chrome", "--web-port=8080"],
      "port": 8080
    },
    {
      "name": "Flutter Web (Web Server)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port=8081"],
      "port": 8081
    },
    {
      "name": "Flutter macOS",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "macos", "--host-vmservice-port=8082"],
      "port": 8082
    }
  ]
}
